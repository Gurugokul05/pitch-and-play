# Database Configuration
MONGO_URI=mongodb://localhost:27017/hackathon_db

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# CORS allowed origins (comma-separated for multiple origins)
# Examples: "http://localhost:5173,http://localhost:5174,https://example.com"
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Email configuration for team registration confirmations
# Gmail setup: Enable 2FA on Google Account > Create App Password > Use app password below
# Custom SMTP: Set EMAIL_HOST, EMAIL_PORT, EMAIL_SECURE, EMAIL_USER, EMAIL_PASS
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
